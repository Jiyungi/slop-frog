{
  "manifest_version": 3,
  "name": "Slop Frog",
  "description": "AI-content flags for X and LinkedIn feeds.",
  "version": "0.1.0",
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://*.modal.run/*",
    "https://api.runtype.com/*",
    "https://*.insforge.app/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": ["src/shared/runtime.js", "src/content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Slop Frog",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  }
}
