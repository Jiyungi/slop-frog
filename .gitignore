# Local credentials and Supabase CLI link state must not be committed.
/.env
/supabase/.temp/
/.modal.toml

# Large local model artifacts are provisioned separately and must not be committed.
/local-detector/models/
/local-detector/.venv/
/local-detector/**/__pycache__/
/modal-detector/**/__pycache__/

# The unpacked extension reads generated local-only configuration. These files
# may contain demo API keys and reviewer identity, never commit them.
/extension/src/shared/product-api-config.local.json
/extension/src/shared/supabase-config.local.json
/benchmark/exports/*.json

# InsForge & AI agent skills
.insforge
.agent
.agents
.augment
.claude
.cline
.github/copilot*
.kilocode
.qoder
.qwen
.roo
.trae
.windsurf
